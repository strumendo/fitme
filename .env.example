# Copy this file to .env and fill in your values. .env is gitignored.

# Garmin Connect credentials. Used only the first time (or if cached tokens expire).
# After a successful login, OAuth tokens are cached at $GARMINTOKENS and re-used.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Optional. Defaults to ~/.garminconnect.
# GARMINTOKENS=~/.garminconnect

# Optional. One of DEBUG, INFO, WARNING, ERROR, CRITICAL. Defaults to INFO.
# LOG_LEVEL=INFO
